{
  "name": "@ants/agent-browser-sandbox",
  "version": "0.1.0",
  "description": "Sandbox browser controller using Playwright with bundled Chromium",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ants/agent-browser-core": "workspace:*",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
