{
  "name": "@openmgr/agent-react-native",
  "version": "0.1.0",
  "description": "React Native bundle package for OpenMgr Agent - combines all RN-compatible packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openmgr/agent-core": "workspace:*",
    "@openmgr/agent-providers": "workspace:*",
    "@openmgr/agent-database-core": "workspace:*",
    "@openmgr/agent-database-react-native": "workspace:*",
    "@openmgr/agent-auth-core": "workspace:*",
    "@openmgr/agent-auth-react-native": "workspace:*",
    "@openmgr/agent-tools": "workspace:*",
    "@openmgr/agent-storage": "workspace:*",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1",
    "expo-auth-session": ">=5.0.0",
    "expo-crypto": ">=12.0.0",
    "expo-secure-store": ">=12.0.0",
    "expo-sqlite": ">=14.0.0",
    "expo-web-browser": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": false
    },
    "expo-auth-session": {
      "optional": true
    },
    "expo-crypto": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "expo-web-browser": {
      "optional": true
    }
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.1",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "keywords": ["openmgr", "agent", "react-native", "expo", "ai", "anthropic"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmgr/agent.git",
    "directory": "packages/react-native"
  }
}
