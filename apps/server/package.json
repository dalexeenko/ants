{
  "name": "@ants/server",
  "version": "0.1.0",
  "description": "Ants Remote Server",
  "author": "Brian Brunner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ants/ants.git",
    "directory": "apps/server"
  },
  "keywords": [
    "ants",
    "agent",
    "ai",
    "agents",
    "remote",
    "server",
    "management"
  ],
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ants-server": "./dist/index.js",
    "ants-server-mcp": "./dist/mcp/index.js",
    "ants": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc; rm -rf dist/db/migrations && cp -r src/db/migrations dist/db/migrations; cp -r node_modules/@ants/server-ui/dist dist/ui 2>/dev/null || true; cp -r node_modules/@ants/app-ui/dist dist/app 2>/dev/null || true",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.8.0",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@ants/agent": "workspace:*",
    "@ants/agent-auth-anthropic": "workspace:*",
    "@ants/agent-auth-core": "workspace:*",
    "@ants/agent-docker": "workspace:*",
    "@ants/agent-memory": "workspace:*",
    "@ants/agent-worktree": "workspace:*",
    "@ants/agent-scheduler": "workspace:*",
    "@ants/agent-storage": "workspace:*",
    "@ants/app-ui": "workspace:*",
    "@ants/server-ui": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "jose": "^6.1.3",
    "node-pty": "1.2.0-beta.11",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
