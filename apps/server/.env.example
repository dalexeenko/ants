# OpenMgr Server - Environment Variables
# Copy this file to .env and fill in your values

# ===================
# REQUIRED
# ===================

# Encryption key for securing sensitive data (API keys, tokens, etc.)
# Generate with: openssl rand -base64 32
OPENMGR_ENCRYPTION_KEY=

# ===================
# OPTIONAL
# ===================

# Server secret for bearer token auth (auto-generated if not set).
# Not required when Cloudflare Access is configured.
# OPENMGR_SECRET=

# Server port (default: 6647)
# OPENMGR_PORT=6647

# Server host (default: 127.0.0.1)
# OPENMGR_HOST=127.0.0.1

# Directory for server data/config (default: ~/.config/openmgr-server)
# OPENMGR_DATA_DIR=

# Directory for project workspaces (default: ~/openmgr)
# OPENMGR_WORKSPACES_DIR=

# Path to the agent CLI binary (auto-detected if not set)
# OPENMGR_AGENT_PATH=

# Auto-install agent if not found (default: true)
# OPENMGR_AUTO_INSTALL_AGENT=true

# Enable mock agent mode for testing without a real agent (default: false)
# OPENMGR_MOCK_AGENT=false

# Allowed Host header values (comma-separated). Protects against DNS rebinding.
# localhost/127.0.0.1/[::1] are always allowed. Set to * to allow any host.
# Default: localhost only.
# OPENMGR_ALLOWED_HOSTS=openmgr.example.com,my-other-domain.com

# ===================
# MULTI-USER MODE (optional)
# ===================

# Enable multi-user mode with role-based access control (default: false)
# OPENMGR_MULTI_USER=false

# Token required for initial admin setup in multi-user mode.
# If not set, the first person to visit /setup becomes admin.
# OPENMGR_SETUP_TOKEN=

# ===================
# WEB APP (optional)
# ===================

# Enable the web app UI at /app (default: false)
# OPENMGR_WEB_APP=false

# ===================
# CORS (optional)
# ===================

# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000,http://127.0.0.1:3000
# OPENMGR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================
# NOTIFICATIONS (optional)
# ===================

# Contact email for VAPID web push notifications (mailto: URI)
# OPENMGR_PUSH_CONTACT_EMAIL=mailto:admin@example.com

# ===================
# LOGGING (optional)
# ===================

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Server version string included in /health and /info responses.
# Set automatically via Docker build arg; can also be set manually.
# OPENMGR_SERVER_VERSION=

# ===================
# CLOUDFLARE ACCESS (optional)
# ===================
# When both TEAM_DOMAIN and AUD are set, Cloudflare Access JWT validation is
# enabled. The server can run without OPENMGR_SECRET when Access is the sole
# auth method. Both must be set together.

# Your Cloudflare Access team domain (e.g. https://myteam.cloudflareaccess.com)
# OPENMGR_CF_ACCESS_TEAM_DOMAIN=

# Application Audience (AUD) tag from your Access application config
# OPENMGR_CF_ACCESS_AUD=

# Extract email from the CF Access JWT and set it as the request identity (default: true)
# OPENMGR_CF_ACCESS_SET_IDENTITY=true
