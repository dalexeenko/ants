# =============================================================================
# Terraform
# =============================================================================

# State files — contain sensitive data (resource IDs, IPs, secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# State directory (when using local backend)
.terraform/

# Lock file generated by terraform init
.terraform.lock.hcl

# Plan files — may contain secrets
*.tfplan
*.plan
out.plan

# Variable files — likely contain secrets (API keys, passwords, ARNs)
*.tfvars
!*.tfvars.example

# Override files — local developer overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# =============================================================================
# Secrets & credentials — NEVER commit these
# =============================================================================

*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore

# AWS
.aws/
credentials
credentials.*

# Environment files
.env
.env.*
!.env.example

# =============================================================================
# OS & editor files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# Editors
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.orig
*~

# =============================================================================
# Misc
# =============================================================================

# Logs
*.log

# Archives (someone zipping up state, etc.)
*.zip
*.tar.gz
*.tgz
